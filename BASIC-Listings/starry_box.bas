1 REM BOUNCY SPOT GENERATOR
2 :
3 REM Draw walls
5 :
10 CLS:PRINT CHR$(2);CHR$(0);:CLS
20 FOR X=0 TO 159
25 T=10
30 PLOT 1,X,8
40 PLOT 1,X,99
50 NEXT X
60 FOR Y=9 TO 98
70 PLOT 1,0,Y
80 PLOT 1,159,Y
90 NEXT Y
100 :
110 REM Setup arrays
120 :
125 REM Number of spots to animate
127 :
130 LOCATE 0,0:PRINT "N=";:INPUT N
140 DIM X(N)
150 DIM Y(N)
160 DIM OX(N)
170 DIM OY(N)
180 DIM XD(N)
190 DIM YD(N)
200 :
210 FOR i=1 TO N
220 X(i)=INT(RND(0)*155)+2
230 Y(i)=INT(RND(0)*80)+10
234 V=RND(0)*2: IF V<1 THEN V=-V ELSE V=V-1
235 U=RND(0)*2: IF U<1 THEN U=-U ELSE U=U-1
240 XD(i)=V:YD(i)=U
250 NEXT i
260 :
270 REM Animate
280 DO
290 FOR i=1 TO N
300 OX(i)=X(i):OY(i)=Y(i)
310 PLOT 0,OX(i),OY(i)
340 X(i)=X(i)+XD(i):IF X(i)<2 OR X(i)>157 THEN XD(i)=-XD(i)
350 Y(i)=Y(i)+YD(i):IF Y(i)<T OR Y(i)>97 THEN YD(i)=-YD(i)
360 PLOT 1,X(i),Y(i)
370 NEXT i
390 LOOP
