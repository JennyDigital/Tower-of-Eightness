10 REM LM77 Temperature grapher20 :30 d$=CHR$(248)40 og=8850 bs=-10: ts=6060 CLS : GOSUB 5000 : IF lb=1 THEN GOSUB 400070 IF lb=0 THEN as=080 GOSUB 11000 : REM Init library90 CLS100 GOSUB 2000110 FOR x=2 TO 159120 FOR x2=1 TO 20130 GOSUB 13000 : r=to : REM Get temp200 GOSUB 1000210 FOR z=1 TO 500: NEXT z215 NEXT x2 : GOSUB 1000220 NEXT x230 GOTO 19997 :998 REM Plotter999 :1000 IF r<bs OR r>ts THEN w$="C. Out of range!    " ELSE w$="                      "1010 LOCATE 0,3:PRINT "Tcurr = ";r;d$;w$1020 IF r<bs THEN r=bs1030 IF r>ts THEN r=ts1040 PLOT 1,x,og-r1050 IF ((r<=lr) OR (r>=hr) AND as=1) THEN GOSUB 30001060 RETURN1997 :1998 REM Graph table drawing1999 :2000 FOR x=0 TO 1592010 IF x/10=INT(x/10) THEN PLOT 1,x,992020 NEXT x2030 LINE 0,98, 159,982040 FOR y=24 TO 992050 IF y/10=INT(y/10) THEN FOR i=0 TO 159 STEP 10: PLOT 1,i,y-2:NEXT i2060 NEXT y2070 LINE 1,24,1,992080 PLOT 0,0,992090 LOCATE 33,0:PRINT "Temperature Graph"2095 PRINT2100 PRINT "X = Time, Y =";bs;d$;"C to";ts;d$;"C";2110 PRINT ". Warning low <=";lr;", high >=";hr;".        "2120 :2125 IF lb=0 THEN RETURN2130 POKE $A13,$55 : REM Set line mode 2 to dotted.2140 LINE 2,og-lr,159,og-lr,2 : LINE 2,og-hr,159,og-hr,22150 PLOT 1,x,og-lr: PLOT 1,x,og-hr2160 RETURN2997 :2998 REM Bell2999 :3000 ENVELOPE 6000,13010 SOUND 0,90,163020 RETURN3997 :3998 REM Get Warning Limits3999 :4000 PRINT "Enter under temperature warning in range ";bs;" to ";ts;4010 INPUT lr4020 IF (ls<bs) OR (lr>ts) THEN PRINT "Out odf range!": GOTO 40404030 PRINT4040 PRINT "Enter over temperature warning in range ";bs;" to ";ts;4050 INPUT hr4060 IF (hr<bs) OR (hr>ts) THEN PRINT "Out of range!": GOTO 40404070 IF hr<=lr THEN PRINT "Ranges overlap! Redo": GOTO 40004080 RETURN4997 :4998 REM Get settings4999 :5000 q$="Do you want an out of bounds alarm sound" : GOSUB 100005010 IF k$="y" OR k$="Y" THEN as=1 ELSE as=05015 IF as=1 THEN lb=1 : RETURN5020 q$="Do you want limit bars" : GOSUB 100005030 IF k$="y" OR k$="Y" THEN lb=1 ELSE lb=05040 RETURN9997 :9998 REM get Yes or no9999 :10000 PRINT q$; : INPUT k$10010 IF (k$<>"n") AND (k$<>"N") AND (k$<>"y") AND (k$<>"Y") THEN GOTO 1000010020 RETURN10997 :10998 REM I2C Initialisation SUB10999 :11000 I2C_INIT11010 :11020 lm=%10010000                : REM LM77 Address11030 ds=%11010000                : REM DS1307 Clock Address11040 wr=0 : rd=1 : nk=1: ak=0    : REM I2C Bus signals11050 RETURN12997 :12998 REM Temperature Read Sub12999 :13000 I2C_START13010 j=I2C_OUT(lm OR wr) : j=I2C_OUT(0)13020 I2C_STOP : I2C_START13030 j=I2C_OUT(lm OR rd)13040 tm=I2C_IN(ak) : tl=I2C_IN(nk) : I2C_STOP13050 to=(tm AND $F) * 32 : to=to+(tl>>3)13060 to=to/213070 IF (tm AND $80) > 0 THEN to=-to+113080 RETURN13997 :13998 REM Get time13999 :14000 REM Reset out output address to 014010 :14020 REM Set address14030 :14040 I2C_START14050 j=I2C_OUT(ds OR wr): j=I2C_OUT(0):I2C_STOP14060 REM  Read packed time14070 :14080 I2C_START14090 j=I2C_OUT(ds OR rd)14100 s=I2C_IN(ak) : m=I2C_IN(ak) : h=I2C_IN(nk)14110 GOSUB 15000 : REM unpack time14120 I2C_STOP14130 RETURN14997 :14998 REM unpack time14999 :15000 w=s15010 s=w AND %111115020 s=s+(10*((w >> 4) AND %111))15030 w=m15040 m=w AND %111115050 m=m+(10*((w >> 4) AND %111))15060 w=h15070 h=w AND %111115080 h=h+(10*((w AND %110000) >> 4))15090 RETURN15995 :15996 REM SetTime subroutine15997 :15998 REM pack time15999 :16000 w=s : GOSUB 17000 : s=w16010 w=m : GOSUB 17000 : m=w16020 w=h : GOSUB 17000 : h=w16030 ch=0 : s=016040 :16050 I2C_START16060 j=I2C_OUT(ds OR wr)        : REM Transmit address in write mode.16070 j=I2C_OUT(0)               : REM Set our address to 016080 j=I2C_OUT(s)16090 j=I2C_OUT(m)16100 j=I2C_OUT(h)16110 I2C_STOP16120 RETURN16997 :16998 REM Binary to BCD convertor16999 :17000 td=017010 bd=017020 DO17030 IF w>9 THEN INC td: w=w-1017040 LOOP UNTIL w<1017050 bd=w17060 w=(td<<4) OR bd17070 RETURN