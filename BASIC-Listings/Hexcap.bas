10 PRINT "Binary over ACIA2 program"20 PRINT30 INPUT "Starting location:";start40 ca=start: POKE $5E2,850 INPUT "Waiting for startcode:";K$60 PRINT "Running"80 DO90 PRINT HEX$(ca,4);:GOSUB 1000: IF rb=-1 THEN 130100 POKE ca,rb120 INC ca130 LOOP UNTIL rb=-1150 PRINT "Finished!"160 bytes=start-ca170 PRINT "Start ";HEX$(start,4);", length ";HEX$(bytes)180 POKE $5E2,1190 END997 :998 REM Hex capture999 :1000 INPUT ": ";K$1010 IF K$="@@" THEN rb=-1 : RETURN1020 K$="$"+K$: rb=VAL(K$) : RETURN