10997 :10998 REM I2C Initialisation SUB10999 :11000 I2C_INIT11010 :11020 lm=%10010000                : REM LM77 Address11030 ds=%11010000                : REM DS1307 Clock Address11040 wr=0 : rd=1 : nk=1: ak=0    : REM I2C Bus signals11050 RETURN12997 :12998 REM Temperature Read Sub12999 :13000 I2C_START13010 j=I2C_OUT(lm OR wr) : j=I2C_OUT(0)13020 I2C_STOP : I2C_START13030 j=I2C_OUT(lm OR rd)13040 tm=I2C_IN(ak) : tl=I2C_IN(nk) : I2C_STOP13050 to=(tm AND $F) * 32 : to=to+(tl>>3)13060 to=to/213070 IF (tm AND $80) > 0 THEN to=-to+113080 RETURN13997 :13998 REM Get time13999 :14000 REM Reset out output address to 014010 :14020 REM Set address14030 :14040 I2C_START14050 j=I2C_OUT(ds OR wr): j=I2C_OUT(0):I2C_STOP14060 REM  Read packed time14070 :14080 I2C_START14090 j=I2C_OUT(ds OR rd)14100 s=I2C_IN(ak) : m=I2C_IN(ak) : h=I2C_IN(nk)14110 GOSUB 15000 : REM unpack time14120 I2C_STOP14130 RETURN14997 :14998 REM unpack time14999 :15000 w=s15010 s=w AND %111115020 s=s+(10*((w >> 4) AND %111))15030 w=m15040 m=w AND %111115050 m=m+(10*((w >> 4) AND %111))15060 w=h15070 h=w AND %111115080 h=h+(10*((w AND %110000) >> 4))15090 RETURN15995 :15996 REM SetTime subroutine15997 :15998 REM pack time15999 :16000 w=s : GOSUB 17000 : s=w16010 w=m : GOSUB 17000 : m=w16020 w=h : GOSUB 17000 : h=w16030 ch=0 : s=016040 :16050 I2C_START16060 j=I2C_OUT(ds OR wr)        : REM Transmit address in write mode.16070 j=I2C_OUT(0)               : REM Set our address to 016080 j=I2C_OUT(s)16090 j=I2C_OUT(m)16100 j=I2C_OUT(h)16110 I2C_STOP16120 RETURN16997 :16998 REM Binary to BCD convertor16999 :17000 td=017010 bd=017020 DO17030 IF w>9 THEN INC td: w=w-1017040 LOOP UNTIL w<1017050 bd=w17060 w=(td<<4) OR bd17070 RETURN